{
  "name": "mcp-portal",
  "version": "0.0.0",
  "description": "CDP Frontend Template",
  "sideEffects": false,
  "main": "src/index.js",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "vite build",
    "build:watch": "vite build --watch",
    "start": "NODE_ENV=production node --env-file-if-exists=.env --use-strict ./src/index.js",
    "start:dev": "NODE_ENV=development run-p build:watch server:watch",
    "server:watch": "nodemon --env-file-if-exists=.env --watch src --watch .public --ext js,njk,yaml,json --ignore src/client --exec 'node --env-file-if-exists=.env --use-strict ./src/index.js'",
    "lint": "run-s lint:js lint:scss",
    "lint:js": "eslint .",
    "lint:scss": "stylelint \"src/**/*.scss\" --cache --cache-location .cache/stylelint --cache-strategy content --color --ignore-path .gitignore",
    "test": "TZ=UTC run-s lint build test:js",
    "test:js": "TZ=UTC vitest run --coverage"
  },
  "author": "Defra DDTS",
  "license": "OGL-UK-3.0",
  "dependencies": {
    "@defra/cdp-auditing": "0.6.0",
    "@defra/cdp-metrics": "0.5.0",
    "@defra/hapi-secure-context": "0.4.0",
    "@defra/hapi-tracing": "1.30.0",
    "@elastic/ecs-pino-format": "1.5.0",
    "@hapi/catbox-memory": "6.0.2",
    "@hapi/catbox-redis": "7.0.2",
    "@hapi/hapi": "21.4.8",
    "@hapi/inert": "7.1.0",
    "@hapi/scooter": "8.0.0",
    "@hapi/vision": "7.0.3",
    "@hapi/yar": "11.0.3",
    "blankie": "5.0.0",
    "convict": "6.2.5",
    "convict-format-with-validator": "6.2.0",
    "date-fns": "4.1.0",
    "flatted": "3.4.2",
    "global-agent": "4.1.3",
    "govuk-frontend": "6.1.0",
    "hapi-pino": "13.0.0",
    "hapi-pulse": "3.0.1",
    "ioredis": "5.10.1",
    "joi": "18.1.2",
    "lodash": "4.18.1",
    "node-fetch": "3.3.2",
    "nunjucks": "3.2.4",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "semver": "7.7.4",
    "undici": "8.1.0",
    "validator": "13.15.35"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.4",
    "autoprefixer": "10.5.0",
    "cssnano": "7.1.7",
    "cssnano-preset-default": "7.0.15",
    "eslint": "9.39.2",
    "neostandard": "0.13.0",
    "nodemon": "3.1.14",
    "npm-run-all2": "8.0.4",
    "postcss-load-config": "6.0.1",
    "postcss-loader": "8.2.1",
    "sass-embedded": "1.99.0",
    "sass-loader": "16.0.7",
    "sharp": "0.34.5",
    "source-map-loader": "5.0.0",
    "stylelint": "17.10.0",
    "stylelint-config-gds": "2.0.0",
    "vite": "8.0.9",
    "vitest": "4.1.4",
    "vitest-fetch-mock": "0.4.5"
  }
}
