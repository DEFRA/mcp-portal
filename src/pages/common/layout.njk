{% extends "govuk/template.njk" %}
{% from "govuk/components/breadcrumbs/macro.njk" import govukBreadcrumbs %}

{% set mainClasses = "app-main-wrapper" %}

{% block head %}
  <link href="{{ getAssetPath('src/client/stylesheets/application.scss') }}" rel="stylesheet">
{% endblock %}

{% block header %}
  <header class="defra-header" role="banner">
    <div class="defra-header__inner">
    <div class="defra-header__brand-group">
      <img
        src="{{ getAssetPath('src/client/images/defra-logo.svg') }}"
        alt="Department for Environment, Food &amp; Rural Affairs"
        class="defra-header__logo"
      />
      <a href="/" class="defra-header__service-name">{{ serviceName }}</a>
    </div>
    </div>
  </header>
  <nav class="defra-service-navigation" aria-label="Service navigation">
    <div class="defra-service-navigation__inner">
      <ul class="defra-service-navigation__list">
        <li class="defra-service-navigation__item">
          <a class="defra-service-navigation__link" href="/" {% if page == 'home' %}aria-current="page"{% endif %}>Home</a>
        </li>
      </ul>
    </div>
  </nav>
{% endblock %}

{% block pageTitle %}
  {{ pageTitle if pageTitle else serviceName }} | {{ serviceName }}
{% endblock %}

{% block beforeContent %}
  {% if breadcrumbs %}
    <div class="govuk-width-container govuk-!-margin-bottom-3">
      {{ govukBreadcrumbs({ items: breadcrumbs }) }}
    </div>
  {% endif %}
{% endblock %}

{% block content %}
{% endblock %}

{% block footer %}
  <footer class="defra-footer" role="contentinfo">
    <div class="govuk-width-container">
      {% if aceSlackChannel %}
        <p class="govuk-body-s govuk-!-margin-top-3 govuk-!-margin-bottom-0">
          Questions? Contact the AICE team on Slack <a class="defra-footer__link" href="{{ aceSlackChannel }}">#ask-ace</a>
        </p>
      {% endif %}
    </div>
  </footer>
{% endblock %}

{% block bodyEnd %}
  <script type="module" src="{{ getAssetPath('src/client/javascripts/application.js') }}"></script>
{% endblock %}
